{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OcrScanOutput",
  "type": "object",
  "required": ["uid", "region", "agents", "modelVersion", "dataVersion", "scanMeta"],
  "properties": {
    "uid": { "type": "string", "pattern": "^[0-9]{6,12}$" },
    "region": { "type": "string", "enum": ["NA", "EU", "ASIA", "SEA", "OTHER"] },
    "modelVersion": { "type": "string" },
    "dataVersion": { "type": "string" },
    "scanMeta": { "type": "string" },
    "resolution": { "type": "string", "enum": ["1080p", "1440p"] },
    "locale": { "type": "string", "enum": ["RU", "EN"] },
    "timingMs": { "type": "number", "minimum": 0 },
    "lowConfReasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "fieldSources": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "confidenceByField": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agentId"],
        "properties": {
          "agentId": { "type": "string" },
          "level": { "type": "number" },
          "levelCap": { "type": "number" },
          "mindscape": { "type": "number" },
          "mindscapeCap": { "type": "number" },
          "stats": {
            "type": "object",
            "additionalProperties": { "type": "number" }
          },
          "weapon": {
            "type": "object",
            "properties": {
              "weaponId": { "type": "string" },
              "displayName": { "type": "string" },
              "level": { "type": "number" },
              "levelCap": { "type": "number" },
              "baseStatKey": { "type": "string" },
              "baseStatValue": { "type": "number" },
              "advancedStatKey": { "type": "string" },
              "advancedStatValue": { "type": "number" }
            },
            "additionalProperties": true
          },
          "weaponPresent": { "type": "boolean" },
          "discSlotOccupancy": {
            "type": "object",
            "additionalProperties": { "type": "boolean" }
          },
          "discs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "slot": { "type": "number" },
                "setId": { "type": "string" },
                "displayName": { "type": "string" },
                "level": { "type": "number" },
                "levelCap": { "type": "number" },
                "mainStatKey": { "type": "string" },
                "mainStatValue": { "type": "number" },
                "substats": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "key": { "type": "string" },
                      "value": { "type": "number" }
                    },
                    "additionalProperties": true
                  }
                }
              },
              "additionalProperties": true
            }
          },
          "confidenceByField": {
            "type": "object",
            "additionalProperties": { "type": "number" }
          },
          "fieldSources": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
